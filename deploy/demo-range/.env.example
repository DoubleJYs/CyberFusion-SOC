# CyberFusion Demo Range example environment.
# Copy to an Environment-local file or export variables in your shell.
# Do not store real tokens or customer data in this source directory.

# Bind the WAF gateway to localhost by default. Use a private RFC1918 address only
# when the host firewall and access controls are already configured.
DEMO_RANGE_BIND_HOST=127.0.0.1
WAF_HTTP_PORT=18081

# Runtime output must live outside the repository.
DEMO_RANGE_RUNTIME_ROOT=/Users/zhangjiyan/Environment/cyberfusion-platform/demo-range

# Enterprise demo target mode: safe, vulnerable, or protected.
DEMO_PORTAL_MODE=protected

# CyberFusion backend API. For Docker Desktop on macOS/Windows, host.docker.internal
# reaches the host. On Linux, docker-compose.yml adds host-gateway for this name.
CYBERFUSION_API_BASE=http://host.docker.internal:18080/api

# Optional bearer token for protected environments. Leave blank for local sessions
# that rely on an already permitted demo backend path or manual curl testing.
CYBERFUSION_API_TOKEN=

# The bridge defaults to dry-run and prints import payloads without sending them.
BRIDGE_DRY_RUN=true
DEMO_BATCH_ID=DEMO-RANGE-DOCKER-LOCAL
